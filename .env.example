# Telegram bot token from @BotFather
BOT_TOKEN=123456:ABC-your-token-here

# PostgreSQL (recommended). Leave blank to use local SQLite (bot.db).
# On Render, paste the Internal Database URL from your Postgres add-on.
DATABASE_URL=

# Optional market data API keys (free tiers work fine)
FINNHUB_KEY=
TWELVEDATA_KEY=

# Default BUY/SELL signal images (admin can change via /setimage)
IMG_BUY=https://i.imgur.com/8wZkQ2T.png
IMG_SELL=https://i.imgur.com/2yQ9pPV.png

# Render assigns PORT automatically for the healthcheck server
PORT=10000
